
// -----------------------------------------------------------------------------
// 6. For-In Loop
// -----------------------------------------------------------------------------

val lines = ["one", "two", "three"];

for (line in lines) {
  print(line);
}

// -----------------------------------------------------------------------------
// 7. Lists and Indexing
// -----------------------------------------------------------------------------

val numbers = [1, 2, 3];
val first = numbers[0];
val nested = [[1, 2], [3, 4]];

// -----------------------------------------------------------------------------
// 8. Records and Field Access
// -----------------------------------------------------------------------------

val order = {
  id: "A12",
  item: "Tea",
  price: 4.50
};

print(order.id);
print(order.price);

// -----------------------------------------------------------------------------
// 9. Functions and Returns
// -----------------------------------------------------------------------------

def sum(x, y) {
  return x + y;
}

def stop() {
  return;
}

print(sum(1, 2));

// -----------------------------------------------------------------------------
// 10. Comments
// -----------------------------------------------------------------------------

// This whole line is a comment.
val commentTest = 1; // This part is also a comment.
// Another comment.
print(commentTest);

// -----------------------------------------------------------------------------
// 11. Multiline Strings
// -----------------------------------------------------------------------------

val text = "hello
world
from Tundra";

print(text);

// -----------------------------------------------------------------------------
// 12. Provenance Helpers
// -----------------------------------------------------------------------------

val raw = read("prices.txt");
val prices = map(splitLines(raw), parseNumber);
val total = sum(prices);

print(total);
print(origin(total));
print(history(total));