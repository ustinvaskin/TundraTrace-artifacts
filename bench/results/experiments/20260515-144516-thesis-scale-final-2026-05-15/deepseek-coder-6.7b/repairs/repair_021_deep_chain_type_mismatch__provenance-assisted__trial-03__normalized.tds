def readAmount(raw)  {
  return raw.invoice.amount;
}

def wrapLine(raw)  {
  return {
    charge: parseNumber(readAmount(raw))
   };
}

val raw = {
  invoice: {
    amount: "40"
   }
};

val line = wrapLine(raw);
val lines = [line];
val subtotal = parseNumber(lines[0].charge); // convert string to number
val fee = 2;
val total = subtotal + fee;

print(total);
