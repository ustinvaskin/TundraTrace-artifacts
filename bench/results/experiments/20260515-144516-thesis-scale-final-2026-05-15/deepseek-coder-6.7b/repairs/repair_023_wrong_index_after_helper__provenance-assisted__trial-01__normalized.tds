def selectRate(rates) {
  return rates[0];
}

val raw = { base: "10",
            rates: [{ label: "old", amount: "2" },
                    { label: "current", amount: "3" }] };
                    
val base = parseNumber(raw.base);
var rate;
rate = selectRate(raw.rates).amount;
var total; 
total = base * parseNumber(rate);
print(total);
