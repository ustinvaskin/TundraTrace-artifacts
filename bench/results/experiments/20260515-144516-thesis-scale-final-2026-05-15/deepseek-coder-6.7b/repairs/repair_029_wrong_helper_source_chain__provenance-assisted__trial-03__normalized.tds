def extractAmount(raw) {
  return raw.backup.total;
}

def makeLine(raw) {
  return {
    amount: extractAmount(raw)
  };
}

var raw = {
  current: {
    total: "25"
  },
  backup: {
    total: "9"
  }
};

val line = makeLine(raw);
val ledger = [line];
val amount = parseNumber(ledger[0].amount);
var fee = 3;
var final = amount + fee;

print(final);
