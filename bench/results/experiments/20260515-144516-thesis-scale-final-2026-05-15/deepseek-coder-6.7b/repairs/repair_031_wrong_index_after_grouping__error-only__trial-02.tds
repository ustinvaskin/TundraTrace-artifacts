def chooseFirstGroupItem(groupItems) {
  return groupItems[0];
}

val groups = [
  {
    name: "archive",
    items: [
      { total: "11" }
     ]
   },
   {
    name: "current",
    items: [
       { total: "27" }
     ]
   }
];

val item = chooseFirstGroupItem(groups[0].items);
val total = parseNumber(item.total) + 2;

print(total);
