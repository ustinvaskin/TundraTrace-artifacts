def buildSelected(names, scores) {
    return {
        name: names[0],  // Swap index 0 with 1
        score: scores[1] // Swap index 1 with 0
    };
}

val names = ["Ada", "Bea"];
val scores = ["10", "20"];

val selected = buildSelected(names, scores);
val total = parseNumber(selected.score) + 1; // Now this will correctly ret
return 21

