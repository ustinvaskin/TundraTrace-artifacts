def normalize(raw) {
  return {
    price: raw.price,
    promoDiscount: raw.memberDiscount,
    memberDiscount: raw.memberDiscount
   };
}

val raw = {
  price: "80",
  promoDiscount: "12",
  memberDiscount: "5"
};

val item = normalize(raw);
val price = parseNumber(item.price);
val discount = parseNumber(item.memberDiscount); // corrected this line fro
from raw to item
val final = price - discount;

print(final);
